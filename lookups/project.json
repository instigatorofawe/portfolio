{
	"$schema": "../node_modules/nx/schemas/project-schema.json",
	"name": "lookups",
	"projectType": "library",
	"targets": {
		"generate-lookups": {
			"executor": "nx:run-commands",
			"cache": true,
			"inputs": [
				"{projectRoot}/CMakeLists.txt",
				"{projectRoot}/src/**/*",
				"{projectRoot}/include/**/*"
			],
			"outputs": [
				"{workspaceRoot}/pushfold/src/generated/equity.rs",
				"{workspaceRoot}/pushfold/src/generated/matchup.rs",
				"{workspaceRoot}/pushfold/src/generated/hands.rs",
				"{workspaceRoot}/pushfold/src/generated/mod.rs"
			],
			"options": {
				"parallel": false,
				"commands": [
					"cmake -S lookups -B lookups/build",
					"cmake --build lookups/build --target generate_pushfold_lookups",
					"lookups/build/generate_pushfold_lookups pushfold/src/generated rust"
				]
			}
		},
		"generate-hands": {
			"executor": "nx:run-commands",
			"cache": true,
			"dependsOn": ["generate-lookups"],
			"inputs": [
				"{projectRoot}/CMakeLists.txt",
				"{projectRoot}/src/**/*",
				"{projectRoot}/include/**/*"
			],
			"outputs": ["{workspaceRoot}/liuran/src/lib/generated/hands.ts"],
			"options": {
				"command": "lookups/build/generate_pushfold_lookups liuran/src/lib/generated ts --hands"
			}
		}
	}
}
