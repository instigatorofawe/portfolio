---
BasedOnStyle: Google
IndentWidth: 4
ColumnLimit: 120
# Regroup includes into three blocks separated by a blank line, in this order:
#   1. system / third-party angle includes  (<cmath>, <gtest/...>, <nanobind/...>)
#   2. our library angle includes           (<dsplib/...>)
#   3. double-quoted includes               ("dsplib/...")
# Regexes are tried top-to-bottom; the first match assigns the priority, so the
# <dsplib/...> rule must precede the catch-all <...> rule.
IncludeBlocks: Regroup
SortIncludes: true
IncludeCategories:
  - Regex: '^<dsplib/'
    Priority: 2
  - Regex: '^<'
    Priority: 1
  - Regex: '^"'
    Priority: 3
